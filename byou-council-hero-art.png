/* Gang color identity */
.mother-badge{display:flex;align-items:center;gap:6px}.mother-badge>i{width:8px;height:8px;border-radius:50%;box-shadow:0 0 9px var(--accent);border:1px solid rgba(255,255,255,.4)}.org-color-chip{display:flex!important;align-items:center;gap:7px;min-width:0}.org-color-chip>i{width:14px;height:14px;flex:none;border-radius:50%;border:2px solid rgba(255,255,255,.28);box-shadow:0 0 12px var(--accent)}.org-color-chip>span{max-width:82px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;font-size:11px;font-weight:500}.org-color-chip>em{margin-left:auto;color:#6f6b62;font:500 8px Montserrat;font-style:normal;letter-spacing:.5px}.org.mother-color:after{content:"";position:absolute;right:-50px;bottom:-70px;width:160px;height:160px;border-radius:50%;background:radial-gradient(circle,color-mix(in srgb,var(--accent) 13%,transparent),transparent 70%);pointer-events:none}.field input[type="color"]{cursor:pointer;border:1px solid rgba(216,185,87,.2);background:#0c0c0a}.field input[type="color"]::-webkit-color-swatch{border:0;border-radius:8px}.field input[type="color"]::-webkit-color-swatch-wrapper{padding:4px}@media(max-width:760px){.org-color-chip>em{display:none}.org-color-chip>span{max-width:95px}}

/* Premium mother-color identity */
.org.mother-color{overflow:hidden;border-width:1px;border-color:color-mix(in srgb,var(--accent) 55%,rgba(229,196,90,.18));background:radial-gradient(circle at 8% 7%,color-mix(in srgb,var(--accent) 12%,transparent),transparent 34%),linear-gradient(145deg,rgba(26,24,18,.94),rgba(8,9,11,.97));box-shadow:0 18px 50px rgba(0,0,0,.36),inset 0 1px 0 color-mix(in srgb,var(--accent) 16%,transparent)}
.org.mother-color:hover{border-color:color-mix(in srgb,var(--accent) 78%,#e5c45a);box-shadow:0 23px 58px rgba(0,0,0,.48),0 0 30px color-mix(in srgb,var(--accent) 13%,transparent)}
.org.mother-color .orgtop{padding-top:34px}
.org.mother-color .mother-badge{left:16px;top:13px;min-height:34px;padding:8px 14px 8px 10px;gap:9px;border:1px solid color-mix(in srgb,var(--accent) 68%,rgba(255,255,255,.12));border-radius:11px;background:linear-gradient(115deg,color-mix(in srgb,var(--accent) 17%,rgba(8,8,10,.94)),rgba(7,8,10,.94));color:color-mix(in srgb,var(--accent) 82%,#fff3c0);font:700 11px/1 Kanit,sans-serif;letter-spacing:.04em;text-shadow:0 0 12px color-mix(in srgb,var(--accent) 35%,transparent);box-shadow:0 8px 20px rgba(0,0,0,.32),0 0 22px color-mix(in srgb,var(--accent) 16%,transparent);backdrop-filter:blur(10px)}
.org.mother-color .mother-badge:before{content:"◆";display:grid;place-items:center;width:21px;height:21px;border:1px solid color-mix(in srgb,var(--accent) 55%,transparent);border-radius:7px;background:color-mix(in srgb,var(--accent) 14%,transparent);color:var(--accent);font-size:9px;box-shadow:inset 0 0 10px color-mix(in srgb,var(--accent) 12%,transparent)}
.org.mother-color .mother-badge>i{width:13px;height:13px;margin-left:1px;border:2px solid rgba(255,255,255,.5);box-shadow:0 0 0 4px color-mix(in srgb,var(--accent) 10%,transparent),0 0 17px var(--accent)}
.org.mother-color .orglogo{width:67px;height:67px;border-color:color-mix(in srgb,var(--accent) 58%,transparent);box-shadow:0 0 0 2px color-mix(in srgb,var(--accent) 13%,transparent),0 0 27px color-mix(in srgb,var(--accent) 24%,transparent)}
.org.mother-color .bar{height:6px;background:color-mix(in srgb,var(--accent) 9%,rgba(255,255,255,.03))}.org.mother-color .bar>i{box-shadow:0 0 14px var(--accent)}
.org.mother-color:after{right:-65px;bottom:-85px;width:220px;height:220px;background:radial-gradient(circle,color-mix(in srgb,var(--accent) 20%,transparent),transparent 68%);filter:blur(2px)}
@media(max-width:760px){.org.mother-color .orgtop{padding-top:31px}.org.mother-color .mother-badge{left:12px;top:11px;min-height:31px;padding:6px 11px 6px 8px;font-size:10px}.org.mother-color .mother-badge:before{width:19px;height:19px}.org.mother-color .orglogo{width:61px;height:61px}}

/* Keep very dark/black mother colors visible on the black dashboard */
.org.mother-color{border-color:color-mix(in srgb,var(--accent) 48%,#d7b956);box-shadow:0 18px 50px rgba(0,0,0,.4),inset 0 1px 0 rgba(255,232,151,.13),0 0 0 1px color-mix(in srgb,var(--accent) 28%,rgba(229,196,90,.16))}
.org.mother-color:hover{border-color:color-mix(in srgb,var(--accent) 38%,#f0d777);box-shadow:0 23px 58px rgba(0,0,0,.5),0 0 28px color-mix(in srgb,var(--accent) 18%,rgba(229,196,90,.18)),inset 0 1px 0 rgba(255,239,181,.18)}
.org.mother-color .mother-badge{border-color:color-mix(in srgb,var(--accent) 45%,#e6ca6c);color:color-mix(in srgb,var(--accent) 52%,#fff0b2);box-shadow:0 8px 20px rgba(0,0,0,.34),0 0 18px color-mix(in srgb,var(--accent) 22%,rgba(229,196,90,.2))}
.org.mother-color .mother-badge:before{border-color:color-mix(in srgb,var(--accent) 42%,#e5c45a);color:color-mix(in srgb,var(--accent) 38%,#ffe48a);background:linear-gradient(145deg,color-mix(in srgb,var(--accent) 18%,rgba(229,196,90,.1)),rgba(255,255,255,.025))}
.org.mother-color .mother-badge>i{border:2px solid #f6e5aa;outline:2px solid color-mix(in srgb,var(--accent) 32%,#bc9b38);outline-offset:2px;box-shadow:0 0 0 5px rgba(229,196,90,.09),0 0 14px color-mix(in srgb,var(--accent) 35%,#caa847)}
.org.mother-color .orglogo{border-color:color-mix(in srgb,var(--accent) 40%,#d9bd62);box-shadow:0 0 0 2px rgba(229,196,90,.1),0 0 24px color-mix(in srgb,var(--accent) 20%,rgba(229,196,90,.17))}
.simple-color i,.org-color-chip>i{border:2px solid #eadcae!important;outline:1px solid rgba(229,196,90,.42);outline-offset:2px}
